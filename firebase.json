{
  "hosting": {
    "public": "public",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/index.html",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/admin.html",
        "destination": "/admin",
        "type": 301
      },
      {
        "source": "/contacto.html",
        "destination": "/contacto",
        "type": 301
      }
    ]
  }
}
